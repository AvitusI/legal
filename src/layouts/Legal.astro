---
interface Props {
  title: string;
  lastUpdated: string;
}

const { title, lastUpdated } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — SwahiliFlow</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        line-height: 1.7;
        color: #1a1a2e;
        background: #fafafa;
      }

      .wrapper {
        max-width: 720px;
        margin: 0 auto;
        padding: 3rem 2rem;
      }

      header { margin-bottom: 2rem; border-bottom: 2px solid #e8e8e8; padding-bottom: 1.5rem; }
      header h1 { font-size: 1.75rem; font-weight: 700; color: #1a1a2e; }
      header p { font-size: 0.875rem; color: #666; margin-top: 0.25rem; }

      h2 { font-size: 1.25rem; font-weight: 600; margin-top: 2rem; margin-bottom: 0.75rem; color: #1a1a2e; }
      p { margin-bottom: 1rem; color: #333; }
      ul { margin-bottom: 1rem; padding-left: 1.5rem; }
      li { margin-bottom: 0.4rem; color: #333; }
      a { color: #e67e22; }

      footer {
        margin-top: 3rem;
        padding-top: 1.5rem;
        border-top: 2px solid #e8e8e8;
        font-size: 0.8rem;
        color: #999;
        text-align: center;
      }
    </style>
  </head>
  <body>
    <div class="wrapper">
      <header>
        <h1>{title}</h1>
        <p>Last updated: {lastUpdated}</p>
      </header>

      <main>
        <slot />
      </main>

      <footer>
        <p>&copy; {new Date().getFullYear()} SwahiliFlow. All rights reserved.</p>
      </footer>
    </div>
  </body>
</html>
